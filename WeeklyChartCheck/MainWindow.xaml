<Window x:Class="WeeklyChartCheck.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeeklyChartCheck"
        xmlns:converters="clr-namespace:WeeklyChartCheck.Converters"
        mc:Ignorable="d"
        Title="Weekly Chart Check" Height="650" Width="1200">
    <Window.Resources>
        <ResourceDictionary>
            <converters:PassColorConverter x:Key="localPassColorConverter"/>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Margin="10,10,10,5">
            <Run Text="Patient id: " FontWeight="Bold"/>
            <Run Text="{Binding PatientId}"/>
        </TextBlock>
        <StackPanel Grid.Row="1" Margin="10,10,10,5">
            <TextBlock Text="Appointments" FontWeight="Bold" FontSize="16"/>
        </StackPanel>

        <DataGrid Grid.Row="2" 
                  Margin="10,5,10,10"
                  ItemsSource="{Binding Appointments}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="LightGray"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{Binding Pass,Converter={StaticResource localPassColorConverter}}"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime}" Width="150"/>
                <DataGridTextColumn Header="Activity" Binding="{Binding ActivityName}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding AppointmentStatus}" Width="100"/>
                <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="150"/>
                <DataGridTextColumn Header="Machine" Binding="{Binding TreatmentMachine}" Width="120"/>
                <DataGridTextColumn Header="MD" Binding="{Binding MD}" Width="120"/>
                <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Margin="10,10,10,5">
            <TextBlock Text="Documents" FontWeight="Bold" FontSize="16"/>
        </StackPanel>

        <DataGrid Grid.Row="4" 
                  Margin="10,5,10,10"
                  ItemsSource="{Binding Documents}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="LightGray"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{Binding Pass,Converter={StaticResource localPassColorConverter}}"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Document Type" Binding="{Binding DocumentType}" Width="150"/>
                <DataGridTextColumn Header="Template" Binding="{Binding DocumentTemplate}" Width="150"/>
                <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="120"/>
                <DataGridTextColumn Header="Supervised By" Binding="{Binding SupervisedBy}" Width="120"/>
                <DataGridTextColumn Header="Signed By" Binding="{Binding SignedBy}" Width="120"/>
                <DataGridTextColumn Header="Approved By" Binding="{Binding ApprovedBy}" Width="120"/>
                <DataGridTextColumn Header="Approval Date" Binding="{Binding ApprovalDate}" Width="120"/>
                <DataGridTextColumn Header="Status" Binding="{Binding ApprovalStatus}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
